    },
    {
      "id": "1000000000000000006",
      "type": "Default",
      "timestamp": "2024-03-12T18:06:20.000+00:00",
      "content": "mana build fell off after the 2.3 patch. they nerfed Arcane Wellspring by 40%. nobody runs it at end-game anymore",
